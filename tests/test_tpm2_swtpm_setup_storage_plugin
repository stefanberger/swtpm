#!/usr/bin/env bash

# For the license, see the LICENSE file in the root directory.
#
# SWTPM_TEST_STORAGE_PLUGIN: set to 0 to skip this test; otherwise it runs.

ROOT=${abs_top_builddir:-$(dirname "$0")/..}
TESTDIR=${abs_top_testdir:-$(dirname "$0")}

source "${TESTDIR}/common"
skip_test_no_tpm20 "${SWTPM_EXE}"

if [ "${SWTPM_TEST_STORAGE_PLUGIN:-1}" = "0" ]; then
	echo "Skipping: SWTPM_TEST_STORAGE_PLUGIN=0"
	exit 77
fi

echo "LD_LIBRARY_PATH: ${LD_LIBRARY_PATH}"

function cleanup_workdir()
{
	rm -rf "${workdir}"
}

# Test 1: force dir plugin fallback.

echo "Test 1: forcing dir backend fallback"

workdir="$(mktemp -d)" || exit 1

if ! LD_LIBRARY_PATH="" \
	$SWTPM_SETUP \
	--tpm2 \
	--overwrite \
	--tpm-state "dir://${workdir}" \
	--config "${SWTPM_SETUP_CONF}" \
	--logfile "${workdir}/logfile" \
	--tpm "${SWTPM_EXE} socket ${SWTPM_TEST_SECCOMP_OPT}";
then
	echo "Test 1 failed: Error: Could not run $SWTPM_SETUP."
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

if ! grep -q "Failed to load plugin " "${workdir}/logfile" 2>/dev/null; then
	echo "Test 1 failed: fallback message missing"
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

echo "Test 1 passed"
cleanup_workdir

# Test 2: force file plugin fallback.

echo "Test 2: forcing file backend fallback"

workdir="$(mktemp -d)" || exit 1
statefile="${workdir}/tpm.state"

if ! LD_LIBRARY_PATH="" \
	$SWTPM_SETUP \
	--tpm2 \
	--overwrite \
	--tpm-state "file://${statefile}" \
	--config "${SWTPM_SETUP_CONF}" \
	--logfile "${workdir}/logfile" \
	--tpm "${SWTPM_EXE} socket ${SWTPM_TEST_SECCOMP_OPT}";
then
	echo "Test 2 failed: Error: Could not run $SWTPM_SETUP."
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

if ! grep -q "Failed to load plugin " "${workdir}/logfile" 2>/dev/null; then
	echo "Test 2 failed: fallback message missing"
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

echo "Test 2 passed"
cleanup_workdir

# Test 3: dir backend — storage plugin loads successfully.

echo "Test 3: dir backend loads storage plugin"

workdir="$(mktemp -d)" || exit 1
echo "LD_LIBRARY_PATH: ${LD_LIBRARY_PATH}"
if ! $SWTPM_SETUP \
	--tpm2 \
	--overwrite \
	--tpm-state "dir://${workdir}" \
	--config "${SWTPM_SETUP_CONF}" \
	--logfile "${workdir}/logfile" \
	--tpm "${SWTPM_EXE} socket ${SWTPM_TEST_SECCOMP_OPT}";
then
	echo "Test 3 failed: Error: Could not run $SWTPM_SETUP."
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

if ! grep -q "Loaded storage plugin" "${workdir}/logfile" 2>/dev/null; then
	echo "Test 3 failed: expected dir storage plugin load message"
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

cat "${workdir}/logfile"

echo "Test 3 passed"
cleanup_workdir

# Test 4: file backend — storage plugin loads successfully.

echo "Test 4: file backend loads storage plugin"

workdir="$(mktemp -d)" || exit 1
statefile="${workdir}/tpm.state"

if ! $SWTPM_SETUP \
	--tpm2 \
	--overwrite \
	--tpm-state "file://${statefile}" \
	--config "${SWTPM_SETUP_CONF}" \
	--logfile "${workdir}/logfile" \
	--tpm "${SWTPM_EXE} socket ${SWTPM_TEST_SECCOMP_OPT}";
then
	echo "Test 4 failed: Error: Could not run $SWTPM_SETUP."
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

if ! grep -q "Loaded storage plugin" "${workdir}/logfile" 2>/dev/null; then
	echo "Test 4 failed: expected file storage plugin load message"
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

cleanup_workdir
echo "Test 4 passed"
cleanup_workdir

exit 0