#!/usr/bin/env bash

# For the license, see the LICENSE file in the root directory.
# Helpers to compile test-only storage plugin shared objects from source when
# SWTPM_TEST_UNINSTALLED is set (no Automake-built .libs in tree).

ROOT=${abs_top_builddir:-$(dirname "$0")/..}
SRCDIR=${abs_top_srcdir:-$(dirname "$0")/..}

function build_dir_wrapper_plugin_so()
{
	local outdir="$1"
	local cc="${CC:-cc}"
	local srcfile="${SRCDIR}/tests/data/swtpm_storage_plugin_dir_wrapper.c"
	local outfile="${outdir}/swtpm_storage_plugin_dir_wrapper.so"
	local glib_cflags glib_libs tpms_cflags

	mkdir -p "${outdir}" || return 1

	if [ ! -r "${srcfile}" ]; then
		echo "Skipping: could not find source file: ${srcfile}"
		return 1
	fi

	glib_cflags="$(pkg-config --cflags glib-2.0)" || return 1
	glib_libs="$(pkg-config --libs glib-2.0)" || return 1
	tpms_cflags="$(pkg-config --cflags libtpms)" || return 1

	# shellcheck disable=SC2086 # pkg-config: multiple flags need word-splitting
	if ! "${cc}" -shared -fPIC -O2 -Wall -Werror \
		-o "${outfile}" "${srcfile}" \
		-I"${ROOT}" \
		-I"${ROOT}/include" \
		-I"${SRCDIR}/include" \
		-I"${SRCDIR}/src" \
		-I"${ROOT}/src/utils" \
		-I"${SRCDIR}/src/utils" \
		-I"${SRCDIR}/src/swtpm" \
		-I"${SRCDIR}/src/swtpm_setup" \
		-I"${SRCDIR}/src/swtpm_storage_plugin" \
		${tpms_cflags} \
		${glib_cflags} ${glib_libs}; then
		echo "Skipping: could not build dir wrapper plugin"
		return 1
	fi
}

function build_dlopen_shim_so()
{
	local outdir="$1"
	local cc="${CC:-cc}"
	local shim_src="${SRCDIR}/tests/data/storage_plugin_dlopen_shim.c"
	local outfile="${outdir}/storage_plugin_dlopen_shim.so"

	if [ -z "${outdir}" ]; then
		echo "build_dlopen_shim_so: missing outdir"
		return 1
	fi

	if [ ! -r "${shim_src}" ]; then
		echo "Skipping: could not find ${shim_src}"
		return 1
	fi

	mkdir -p "${outdir}" || return 1

	if ! "${cc}" -shared -fPIC -O2 -Wall -Werror \
		-o "${outfile}" "${shim_src}" \
		-I"${SRCDIR}/include" \
		-I"${ROOT}/include" \
		-ldl; then
		echo "Skipping: could not build dlopen shim"
		return 1
	fi
}

action="$1"
outdir="$2"

case "${action}" in
	"build_dir_wrapper_plugin_so")
		build_dir_wrapper_plugin_so "${outdir}"
		;;
	"build_dlopen_shim_so")
		build_dlopen_shim_so "${outdir}"
		;;
	"build_all")
		build_dir_wrapper_plugin_so "${outdir}" || exit 1
		build_dlopen_shim_so "${outdir}" || exit 1
		;;
	*)
		echo "Usage: $0 <build_dir_wrapper_plugin_so|build_dlopen_shim_so|build_all> <outdir>"
		exit 1
		;;
esac
