#!/usr/bin/env bash

# For the license, see the LICENSE file in the root directory.

if [ "${SWTPM_TEST_PLUGINBACKEND:-0}" -eq 0 ]; then
	echo "Skipping test_tpm2_swtpm_setup_plugin_backend: SWTPM_TEST_PLUGINBACKEND is not set"
	exit 77
fi

if [ "$(id -u)" -ne 0 ]; then
	echo "Skipping test_tpm2_swtpm_setup_plugin_backend: Must be run as root."
	exit 77
fi

ROOT=${abs_top_builddir:-$(dirname "$0")/..}
TESTDIR=${abs_top_testdir:-$(dirname "$0")}
# Determine a test user and group
if ! id -u tss &>/dev/null; then
	echo "Could not find suitable user/group for plugin backend testing."
	exit 77
fi
TESTUSER=tss
TESTGROUP="$(getent group "$(id -g "${TESTUSER}")" | cut -d':' -f1)"

if [ -z "${TESTUSER}" ] || [ -z "${TESTGROUP}" ]; then
	echo "Could not find suitable user/group for plugin backend testing."
	exit 77
fi

source "${TESTDIR}/common"
source "${TESTDIR}/build_pluginbackend"
skip_test_no_tpm20 "${SWTPM_EXE}"
STATEBASENAME="tpm2-00.permall"

trap "cleanup_all" SIGTERM EXIT

function cleanup_workdir()
{
	rm -rf "${workdir}"
}

function cleanup_all()
{
	cleanup_workdir
	rm -rf "${plugin_dir}"
}

function make_backend_uri()
{
	local state_dir="$1"
	printf 'plugin://%s?path=%s' "${plugin_so}" "${state_dir}"
}

plugin_dir="$(mktemp -d)" || exit 1
build_dir_plugin_so "${plugin_dir}"
plugin_so="${plugin_dir}/swtpm_nvram_backend_dir.so"
chown -R "${TESTUSER}:${TESTGROUP}" "${plugin_dir}"

# Test 1: --not-overwrite with dummy state file
workdir="$(mktemp -d)" || exit 1
statefile="${workdir}/${STATEBASENAME}"
logfile="${workdir}/logfile" && touch "${logfile}"
dummydata="DUMMY" && echo "$dummydata" > "${statefile}"
chown -R "${TESTUSER}:${TESTGROUP}" "${workdir}" || exit 1
backend_uri="$(make_backend_uri "${workdir}")"
if ! $SWTPM_SETUP \
	--tpm2 \
	--not-overwrite \
	--tpm-state "${backend_uri}" \
	--config "${SWTPM_SETUP_CONF}" \
	--logfile "${logfile}" \
	--runas ${TESTUSER} \
	--tpm "${SWTPM_EXE} socket ${SWTPM_TEST_SECCOMP_OPT}";
then
	echo "Test 1 failed: Error: Could not run $SWTPM_SETUP."
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

if ! grep -q "${dummydata}" "${statefile}"; then
	echo "Test 1 failed: Error: The state file was unexpectedly overwritten."
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

echo "Test 1 passed"
cleanup_workdir

# Test 2: --overwrite with dummy state file

workdir="$(mktemp -d)" || exit 1
statefile="${workdir}/${STATEBASENAME}"
logfile="${workdir}/logfile"
dummydata="DUMMY" && echo "$dummydata" > "${statefile}"
logfile="${workdir}/logfile" && touch "${logfile}"
chown -R "${TESTUSER}:${TESTGROUP}" "${workdir}" || exit 1
backend_uri="$(make_backend_uri "${workdir}")"
if ! $SWTPM_SETUP \
	--tpm2 \
	--overwrite \
	--tpm-state "${backend_uri}" \
	--config "${SWTPM_SETUP_CONF}" \
	--logfile "${logfile}" \
	--runas ${TESTUSER} \
	--tpm "${SWTPM_EXE} socket ${SWTPM_TEST_SECCOMP_OPT}";
then
	echo "Test 2 failed: Error: Could not run $SWTPM_SETUP."
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

if grep -q "${dummydata}" "${statefile}"; then
	echo "Test 2 failed: Error: The state file was not overwritten."
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

echo "Test 2 passed"
cleanup_workdir

# Test 3: neither "--overwrite" nor "--not-overwrite" with dummy state file

workdir="$(mktemp -d)" || exit 1
statefile="${workdir}/${STATEBASENAME}"
dummydata="DUMMY" && echo "$dummydata" > "${statefile}"
logfile="${workdir}/logfile" && touch "${logfile}"
chown -R "${TESTUSER}:${TESTGROUP}" "${workdir}" || exit 1
backend_uri="$(make_backend_uri "${workdir}")"

if $SWTPM_SETUP \
	--tpm2 \
	--tpm-state "${backend_uri}" \
	--config "${SWTPM_SETUP_CONF}" \
	--logfile "${logfile}" \
	--runas ${TESTUSER} \
	--tpm "${SWTPM_EXE} socket ${SWTPM_TEST_SECCOMP_OPT}";
then
	echo "Test 3 failed: Error: $SWTPM_SETUP did not exit with exit code 1."
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

if ! grep -q "${dummydata}" "${statefile}"; then
	echo "Test 3 failed: Error: The state file was unexpectedly overwritten."
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

echo "Test 3 passed"

# Test 4: Root execution must reject plugin backend loading.
workdir="$(mktemp -d)" || exit 1
backend_uri="$(make_backend_uri "${workdir}")"
if $SWTPM_SETUP \
	--tpm2 \
	--overwrite \
	--tpm-state "${backend_uri}" \
	--config "${SWTPM_SETUP_CONF}" \
	--logfile "${workdir}/logfile" \
	--runas root \
	--tpm "${SWTPM_EXE} socket ${SWTPM_TEST_SECCOMP_OPT}";
then
	echo "Test 4 failed: Error: $SWTPM_SETUP did not exit with exit code 1."
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

if ! grep -q "Refusing plugin backend " "${workdir}/logfile" ||
   ! grep -q "while running as root" "${workdir}/logfile"; then
	echo "Test 4 failed: expected root-rejection message is missing."
	echo "Setup Logfile:"
	cat "${workdir}/logfile"
	exit 1
fi

echo "Test 4 passed"

cleanup_all
exit 0
