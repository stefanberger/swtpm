#!/usr/bin/env bash

# For the license, see the LICENSE file in the root directory.
# TPM2 swtpm_setup external storage plugin tests.
#
# SWTPM_TEST_STORAGE_PLUGIN: set to 0 to skip this test; otherwise it runs.

ROOT=${abs_top_builddir:-$(dirname "$0")/..}
TESTDIR=${abs_top_testdir:-$(dirname "$0")}

source "${TESTDIR}/common"
source "${TESTDIR}/storage_plugin_common"
skip_test_no_tpm20 "${SWTPM_EXE}"
# ASAN/LSAN + --runas can fatal or non-zero exit at teardown though setup succeeded.
skip_test_linked_with_asan "${SWTPM_EXE}"
skip_test_linked_with_asan "${SWTPM_SETUP}"

if [ "${SWTPM_TEST_STORAGE_PLUGIN:-1}" = "0" ]; then
	echo "Skipping: SWTPM_TEST_STORAGE_PLUGIN=0"
	exit 77
fi

if [ "$(id -u)" -eq 0 ]; then
	# Determine a test user/group for running swtpm_setup unprivileged.
	if ! id -u nobody &>/dev/null; then
		echo "Could not find suitable user/group for external storage plugin testing."
		exit 77
	fi
	TESTUSER=nobody
	TESTGROUP="$(getent group "$(id -g "${TESTUSER}")" | cut -d':' -f1)"

	if [ -z "${TESTUSER}" ] || [ -z "${TESTGROUP}" ]; then
		echo "Could not find suitable user/group for external storage plugin testing."
		exit 77
	fi
	RUNAS="--runas ${TESTUSER}"

else
	RUNAS=""
fi

trap "cleanup_all" SIGTERM EXIT

function cleanup_workdir()
{
	rm -rf "${workdir}"
}

function cleanup_all()
{
	cleanup_workdir
	rm -rf "${plugin_dir}"
}

function make_backend_uri()
{
	local state_dir="$1"
	echo "plugin://${plugin_so}?path=${state_dir}"
}

function prepare_swtpm_for_test_user()
{
	# We need to copy swtpm and libswtpm_libtpms.so to the workdir
	# so that swtpm_setup can access it as TESTUSER
	if ! file "${SWTPM_EXE}" | grep -q ELF; then
		directory="$(dirname "${SWTPM_EXE}")/.libs"
		if [ -d "${directory}" ]; then
			cp "${directory}/swtpm" "${workdir}"
			cp "${directory}"/libswtpm_libtpms.so* "${workdir}"
		else
			echo "Could not find .libs directory to copy swtpm from."
			exit 77
		fi

		MY_SWTPM_EXE="${workdir}/swtpm"
		SWTPM_LD_LIBRARY_PATH="${workdir}:${LD_LIBRARY_PATH:-}"
	else
		MY_SWTPM_EXE="${SWTPM_EXE}"
		SWTPM_LD_LIBRARY_PATH=""
	fi

	chown -R "${TESTUSER}:${TESTGROUP}" "${workdir}" || exit 1
}

plugin_dir="$(mktemp -d)" || exit 1
build_dir_wrapper_plugin_so "${plugin_dir}"
plugin_so="${plugin_dir}/swtpm_storage_plugin_dir_wrapper.so"
MY_SWTPM_EXE="${SWTPM_EXE}"
SWTPM_LD_LIBRARY_PATH="${LD_LIBRARY_PATH:-}"
if [ -n "${RUNAS}" ]; then
	chown -R "${TESTUSER}:${TESTGROUP}" "${plugin_dir}" || exit 1
fi

# Test 1: external storage plugin loads and initializes TPM state.
workdir="$(mktemp -d)" || exit 1
logfile="${workdir}/logfile"
touch "${logfile}"
backend_uri="$(make_backend_uri "${workdir}")"
if [ -n "${RUNAS}" ]; then
	prepare_swtpm_for_test_user
fi

if ! LD_LIBRARY_PATH="${SWTPM_LD_LIBRARY_PATH}" ${SWTPM_SETUP} \
	--tpm2 \
	--overwrite \
	--tpm-state "${backend_uri}" \
	--config "${SWTPM_SETUP_CONF}" \
	--logfile "${logfile}" \
	${RUNAS:+${RUNAS}} \
	--tpm "${MY_SWTPM_EXE} socket ${SWTPM_TEST_SECCOMP_OPT}";
then
	echo "Test 1 failed: Error: Could not run $SWTPM_SETUP."
	echo "Setup Logfile:"
	cat "${logfile}"
	exit 1
fi

if ! grep -q "Loaded storage plugin" "${logfile}"; then
	echo "Test 1 failed: expected external storage plugin load message."
	echo "Setup Logfile:"
	cat "${logfile}"
	exit 1
fi

if ! ls "${workdir}"/tpm2-00.* >/dev/null 2>&1; then
	echo "Test 1 failed: expected TPM2 state files in ${workdir}."
	echo "Setup Logfile:"
	cat "${logfile}"
	exit 1
fi

cat "${logfile}"

echo "Test 1 passed"
cleanup_workdir

# Test 2: running as root without --runas must reject custom plugin loading.
if [ "$(id -u)" -eq 0 ]; then
	workdir="$(mktemp -d)" || exit 1
	logfile="${workdir}/logfile"
	touch "${logfile}"
	backend_uri="$(make_backend_uri "${workdir}")"

	if $SWTPM_SETUP \
		--tpm2 \
		--overwrite \
		--tpm-state "${backend_uri}" \
		--config "${SWTPM_SETUP_CONF}" \
		--logfile "${logfile}" \
		--tpm "${SWTPM_EXE} socket ${SWTPM_TEST_SECCOMP_OPT}";
	then
		echo "Test 2 failed: Error: $SWTPM_SETUP did not exit with exit code 1."
		echo "Setup Logfile:"
		cat "${logfile}"
		exit 1
	fi

	if ! grep -q "external storage plugin .* can not be loaded by high-privileged user" "${logfile}"; then
		echo "Test 2 failed: expected root-rejection message is missing."
		echo "Setup Logfile:"
		cat "${logfile}"
		exit 1
	fi

	echo "Test 2 passed"
else
	echo "Test 2 skipped (not running as root)"
fi

cleanup_all
exit 0